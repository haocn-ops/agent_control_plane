    "handoff_markdown": ".onboarding-bundles/tenant_acme/handoff.md",
    "handoff_state_json": ".onboarding-bundles/tenant_acme/handoff-state.json",
    "provisioning_request_json": ".onboarding-bundles/tenant_acme/provisioning-request.json",
    "rollback_request_json": ".onboarding-bundles/tenant_acme/rollback-request.json",
    "seed_sql": ".onboarding-bundles/tenant_acme/seed.sql",
    "provision_script": ".onboarding-bundles/tenant_acme/provision.sh",
    "apply_request_script": ".onboarding-bundles/tenant_acme/apply-request.sh",
    "submit_request_script": ".onboarding-bundles/tenant_acme/submit-request.sh",
    "complete_handoff_script": ".onboarding-bundles/tenant_acme/complete-handoff.sh",
    "rollback_script": ".onboarding-bundles/tenant_acme/rollback.sh",
    "status_script": ".onboarding-bundles/tenant_acme/status.sh",
    "verify_script": ".onboarding-bundles/tenant_acme/verify.sh"
  },
  "external_handoff": {
    "request_owner": "<fill-me>",
    "requester_team": "<fill-me>",
    "change_ticket": "<fill-me>",
    "target_completion_date": "<fill-me>",
    "approver": "<fill-me>",
    "external_system_record": "<fill-me>"
  },
  "actions": [
    {
      "action_id": "seed_import",
      "type": "d1_seed_import",
      "required": true,
      "command": "wrangler d1 execute agent-control-plane-staging --remote --file /abs/path/seed.sql --env staging",
      "evidence_path": ".onboarding-bundles/tenant_acme/seed.sql"
    },
    {
      "action_id": "handoff_submission",
      "type": "external_submission",
      "required": true,
      "command": "./submit-request.sh https://<ticket-or-cmdb-endpoint>",
      "evidence_path": ".onboarding-bundles/tenant_acme/provisioning-submit-evidence.json"
    },
    {
      "action_id": "provider_overrides",
      "type": "tool_provider_override",
      "required": true,
      "items": [
        {
          "tool_provider_id": "tp_email",
          "name": "Email Gateway",
          "provider_type": "mcp_server",
          "current_endpoint_url": "mock://email",
          "desired_endpoint_url": "<fill-me>",
          "current_auth_ref": null,
          "desired_auth_ref": "<fill-me>",
          "visibility_policy_ref": null,
          "execution_policy_ref": null,
          "current_status": "active",
          "desired_status": "active",
          "suggested_secret_binding_name": "<fill-me>",
          "required_before_verification": true,
          "status": "active"
        }
      ]
    },
    {
      "action_id": "policy_review",
      "type": "policy_review",
      "required": true,
      "items": [
        {
          "policy_id": "pol_mcp_email_external_approval_v1",
          "channel": "mcp_tool_call",
          "scope": {
            "tool_provider_id": "tp_email",
            "tool_name": "send_email"
          },
          "conditions": {
            "target_classification": "external",
            "risk_level": "high"
          },
          "decision": "approval_required",
          "approval_config": {
            "approver_roles": [
              "legal_approver"
            ],
            "timeout_seconds": 86400
          },
          "priority": 100,
          "tool_provider_id": "tp_email",
          "tool_name": "send_email",
          "status": "active",
          "review_required": true,
          "desired_policy": null
        }
      ]
    },
    {
      "action_id": "apply_bundle_changes",
      "type": "bundle_apply",
      "required": true,
      "command": "./apply-request.sh write",
      "evidence_path": ".onboarding-bundles/tenant_acme/apply-request-evidence.json"
    },
    {
      "action_id": "verification",
      "type": "post_deploy_verify",
      "required": true,
      "mode": "write",
      "command": "./verify.sh write",
      "evidence_path": ".onboarding-bundles/tenant_acme/verify-write-summary.json"
    },
    {
      "action_id": "handoff_complete",
      "type": "handoff_state_update",
      "required": true,
      "command": "./complete-handoff.sh",
      "evidence_path": ".onboarding-bundles/tenant_acme/handoff-state.json"
    }
  ],
  "completion_criteria": [
    "external submission evidence is attached to the bundle",
    "provider endpoint_url and auth_ref are updated from mock defaults",
    "required secrets are provisioned in the target Worker environment",
    "policy review is recorded in the external system",
    "verify summary JSON is attached to the handoff evidence",
    "handoff-state.json reflects the final operator-visible status"
  ]
}
